{
  "expo": {
    "name": "ICU Logbook",
    "slug": "icu-logbook",
    "scheme": "iculogbook",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.iculogbook.app"
    },
    "android": {
      "package": "com.iculogbook.app"
    },
    "web": {},
    "plugins": [
      [
        "expo-sqlite",
        {
          "enableFTS": false,
          "useSQLCipher": false
        }
      ],
      "expo-asset",
      "expo-font",
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      "sentry-expo"
    ]
  }
}
