<?xml version="1.0" encoding="utf-8"?>
<!--
  Data extraction rules for expo-secure-store (Android 12+ / API 31+).
  Excludes the SecureStore shared preferences from both cloud backup
  and device-to-device transfer so encrypted keys stay on-device.
-->
<data-extraction-rules>
  <cloud-backup>
    <exclude domain="sharedpref" path="SecureStore"/>
  </cloud-backup>
  <device-transfer>
    <exclude domain="sharedpref" path="SecureStore"/>
  </device-transfer>
</data-extraction-rules>
